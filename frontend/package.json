{
  "name": "prolux-group",
  "version": "0.1.0",
  "private": true,
  "author": "PROLUX Group",
  "dependencies": {
    "antd": "^5.26.2",
    "axios": "^1.10.0",
    "dayjs": "^1.11.13",
    "electron-is-dev": "^2.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "react-scripts": "5.0.1"
  },
  "scripts": {
    "start": "node scripts/react-scripts-runner.js start",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm start\" \"node scripts/wait-for-frontend.js && electron .\"",
    "prebuild": "node scripts/validate-production-env.js",
    "build": "node scripts/react-scripts-runner.js build",
    "backend:build": "dotnet build ../backend/backend.csproj",
    "publish-backend": "dotnet publish ../backend/backend.csproj -c Release -r win-x64 --self-contained true -o ../artifacts/backend-publish",
    "build-electron": "npm run clean:artifacts && npm run build && npm run publish-backend && electron-builder",
    "test": "node scripts/react-scripts-runner.js test --watchAll=false --runInBand --passWithNoTests",
    "test:watch": "node scripts/react-scripts-runner.js test --watchAll",
    "check": "npm run backend:build && npm run build && npm test",
    "clean:artifacts": "node scripts/clean-artifacts.js",
    "eject": "react-scripts eject",
    "desktop": "npm run electron-dev"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "electron": "^37.1.0",
    "electron-builder": "^25.1.0"
  },
  "main": "public/electron.js",
  "homepage": ".",
  "build": {
    "appId": "com.proluxgroup.app",
    "productName": "PROLUX Group",
    "directories": {
      "output": "dist-new"
    },
    "files": [
      "build/**/*",
      "public/electron.js",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../artifacts/backend-publish",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/prolux-logo.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/prolux-logo.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/prolux-logo.png"
    }
  }
}
